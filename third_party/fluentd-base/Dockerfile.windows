ARG WINDOWS_VERSION

### Install Ruby and DevKit

FROM mcr.microsoft.com/windows/servercore:${WINDOWS_VERSION}-amd64

RUN powershell -Command "Invoke-WebRequest -Uri https://github.com/oneclick/rubyinstaller2/releases/download/RubyInstaller-3.4.8-1/rubyinstaller-devkit-3.4.8-1-x64.exe -OutFile C:\rubyinstaller.exe; `
    Start-Process -FilePath C:\rubyinstaller.exe -ArgumentList '/allusers /norestart /tasks=assocfiles,modpath /verysilent /dir=C:\ruby34' -Wait; `
    & C:\ruby34\bin\ridk.cmd install 1 2 3; `
    & C:\ruby34\msys64\usr\bin\pacman -S --noconfirm jq; `
    Remove-Item -Force C:\rubyinstaller.exe"

# https://github.com/fluent/fluentd-docker-image/blob/master/v1.19/windows-ltsc2019/Dockerfile

RUN type "C:\ProgramData\gemrc" && `
    C:\ruby34\bin\ruby -r yaml -e "path = 'C:/ProgramData/gemrc'; yaml = YAML.safe_load(File.read(path)); yaml['install'] = '--no-document'; yaml['update'] = '--no-document'; File.write(path, YAML.dump(yaml))" && `
    type "C:\ProgramData\gemrc" && `
    gem install fluentd -v 1.19.2 && `
    gem install json -v 2.13.2 && `
    gem install oj -v 3.16.11 && `
    gem install rexml -v 3.4.4 && `
    gem install win32-event -v 0.6.3 && `
    gem install win32-ipc -v 0.7.0 && `
    gem install win32-service -v 2.3.2 && `
    gem sources --clear-all

# Remove gem cache
RUN powershell -Command "Remove-Item -Force C:\ruby34\lib\ruby\gems\3.4.0\cache\*.gem"

### Calico Enterprise dependencies

# - Add symlink to ruby install path.
#   - The ruby version gets updated occasionally so using a symlink
#     keeps us from needing to update the fluentd probes in the operator.
RUN mklink /D c:\ruby c:\ruby34

# - Install Calico Enterprise dependencies
RUN gem install elasticsearch-api -v 8.19.3 && `
    gem install elasticsearch-transport -v 7.17.11 && `
    gem install elasticsearch-xpack -v 7.17.11 && `
    gem install elasticsearch -v 8.19.3 && `
    gem install fluent-plugin-cloudwatch-logs -v 0.15.0 && `
    gem install fluent-plugin-elasticsearch -v 6.0.0 && `
    gem install fluent-plugin-prometheus -v 2.2.1 && `
    gem install fluent-plugin-remote_syslog -v 1.1.0 && `
    gem install fluent-plugin-s3 -v 1.8.3 && `
    gem install fluent-plugin-splunk-hec -v 1.3.3 && `
    gem sources --clear-all

RUN mkdir C:\fluentd\etc && `
    mkdir C:\fluentd\etc\output_bgp && `
    mkdir C:\fluentd\etc\output_compliance_reports && `
    mkdir C:\fluentd\etc\output_dns && `
    mkdir C:\fluentd\etc\output_flows && `
    mkdir C:\fluentd\etc\output_non_cluster_flows && `
    mkdir C:\fluentd\etc\output_ids_events && `
    mkdir C:\fluentd\etc\output_kube_audit && `
    mkdir C:\fluentd\etc\output_l7 && `
    mkdir C:\fluentd\etc\output_runtime && `
    mkdir C:\fluentd\etc\output_tsee_audit && `
    mkdir C:\fluentd\etc\output_waf && `
    mkdir C:\fluentd\etc\output_policy && `
    mkdir C:\fluentd\plugins

COPY rubyplugin/out_http.rb /fluentd/plugins/out_http.rb
